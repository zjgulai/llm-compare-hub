      "id": "image",
      "name": "图像生成 API",
      "description": "POST /v1/images/generations - 图片URL有效期1小时，请及时下载保存",
      "endpoint": "POST /v1/images/generations",
      "auth": "Authorization: Bearer YOUR_API_KEY",
      "commonParams": {
        "model": "string (required) - 如 Kwai-Kolors/Kolors",
        "prompt": "string (required) - 文本描述",
        "negative_prompt": "string (optional) - 负面提示",
        "image_size": "string (required, 格式: widthxheight) - 推荐值见各模型文档",
        "batch_size": "integer (optional, default: 1) - 生成数量 1-4",
        "num_inference_steps": "integer (optional, default: 20) - 推理步数",
        "guidance_scale": "number (optional, default: 7.5) - CFG scale",
        "image": "string (optional) - 图生图时的参考图URL/base64",
        "strength": "number (optional) - 图生图强度 0-1",
        "seed": "integer (optional) - 随机种子"
      },
      "response": {
        "images": [
