{
  "platform": "siliconflow",
  "platformName": "硅基流动 (SiliconFlow)",
  "platformUrl": "https://www.siliconflow.cn",
  "docsUrl": "https://docs.siliconflow.cn",
  "apiOverview": {
    "baseUrl": "https://api.siliconflow.cn",
    "authentication": {
      "type": "Bearer Token",
      "header": "Authorization: Bearer YOUR_API_KEY",
      "note": "获取API Key: https://cloud.siliconflow.cn/account/ak"
    },
    "architecture": "所有模型统一通过 OpenAI 兼容格式调用，支持流式(stream)输出，部分模型支持 Anthropic 原生格式"
  },
  "categories": [
    {
      "id": "chat",
      "name": "文本对话 API",
      "description": "POST /v1/chat/completions (OpenAI兼容格式) | 支持流式输出",
      "endpoint": "POST /v1/chat/completions",
      "auth": "Authorization: Bearer YOUR_API_KEY",
      "commonParams": {
        "model": "string (required) - 模型名称",
        "messages": "array (required) - 对话消息列表 [{role, content}]",
        "stream": "boolean (optional, default: false) - 是否流式返回 SSE",
        "max_tokens": "integer (optional) - 最大生成token数，预留~10K buffer",
        "temperature": "number (optional, default: 0.7) - 采样温度",
        "top_p": "number (optional, default: 0.7) - 核采样概率阈值",
        "top_k": "integer (optional) - Top-K采样",
        "frequency_penalty": "number (optional, default: 0) - 频率惩罚",
        "presence_penalty": "number (optional, default: 0) - 存在惩罚",
        "n": "integer (optional, default: 1) - 生成数量",
        "stop": "string/array (optional) - 停止词",
        "tools": "array (optional) - 工具定义",
        "tool_choice": "string/object (optional) - 工具选择策略",
        "response_format": "object (optional) - 输出格式如json_schema"
      },
      "response": {
        "id": "string",
        "object": "chat.completion",
        "created": "integer",
        "model": "string",
        "choices": [
          {
            "index": 0,
            "message": {
              "role": "assistant",
              "content": "string",
              "reasoning_content": "string"
            },
            "finish_reason": "string"
          }
        ],
        "usage": {
          "prompt_tokens": "integer",
          "completion_tokens": "integer",
          "total_tokens": "integer",
          "completion_tokens_details": {
            "reasoning_tokens": "integer"
          },
          "prompt_tokens_details": {
            "cached_tokens": "integer"
          },
          "prompt_cache_hit_tokens": "integer",
          "prompt_cache_miss_tokens": "integer"
        }
      },
